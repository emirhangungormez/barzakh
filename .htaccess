# Bu dosya Emirhan Güngörmez tarafından hazırlanmıştır. İletişim: han23studio@gmail.com

# 404 ve diğer hata sayfaları
ErrorDocument 404 /404.html

# HTTPS Yönlendirmesi
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www kaldırma (Opsiyonel)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Directory indexing kapatma
Options -Indexes

# UTF-8 Zorlama
AddDefaultCharset UTF-8

# Video MIME Tipleri
AddType video/mp4 .mp4
AddType video/webm .webm
AddType video/ogg .ogv

# ========================================
# SECURITY HEADERS
# ========================================

# XSS Koruması
<IfModule mod_headers.c>
    # Clickjacking koruması
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # XSS Filter
    Header always set X-XSS-Protection "1; mode=block"
    
    # MIME sniffing koruması
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy (eski Feature-Policy)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://shared.akamai.steamstatic.com https://img.youtube.com https://www1.wdr.de data:; media-src 'self' https://video.akamai.steamstatic.com; frame-src https://www.youtube.com https://store.steampowered.com; connect-src 'self' https://store.steampowered.com;"
    
    # HSTS (HTTP Strict Transport Security) - 1 yıl
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ========================================
# DOSYA ERİŞİM GÜVENLİĞİ
# ========================================

# .htaccess dosyasına erişimi engelle
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# Hassas dosyaları koru
<FilesMatch "\.(env|log|ini|sh|sql|bak|config)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP dosyalarını koru (sadece fetch_steam.php hariç)
<FilesMatch "^(?!fetch_steam\.php$).*\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>